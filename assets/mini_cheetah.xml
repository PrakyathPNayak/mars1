        <joint name="FR_hip_joint" axis="1 0 0" range="-1.0472 0.872665" damping="0.5" armature="0.01"/>
        <geom name="FR_hip_visual" type="mesh" mesh="hip_mesh" material="hip_mat" euler="0 3.14159 0" contype="0" conaffinity="0"/>
