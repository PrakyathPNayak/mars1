              <geom name="FR_foot_collision" type="sphere" size="0.025" pos="0 0 0.025" material="foot_mat" condim="6" friction="1.5 0.005 0.0001" solimp="0.9 0.95 0.001" solref="0.02 1"/>
              <site name="FR_foot_site" pos="0 0 0" size="0.01"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ═══ FL (Front-Left) leg ═══ -->
